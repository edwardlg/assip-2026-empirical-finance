# =============================================================================
# ASSIP 2026 — .gitignore
# Excludes build artifacts, secrets, and licensed/large data so only source
# files are committed.
# =============================================================================

# ---- Python -----------------------------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
env/

# ---- Build artifacts: Quarto + MkDocs --------------------------------------
_site/
.quarto/
_freeze/
_book/
wiki/site/
wiki/.cache/

# ---- Locks (we pin via environment.yml / requirements.txt instead) ---------
*.lock

# ---- Data (licensed data must NOT be committed) -----------------------------
data/
*.parquet
*.csv
!data-cards/**

# ---- OS / editor ------------------------------------------------------------
.DS_Store
.vscode/

# ---- Secrets ----------------------------------------------------------------
.env
*.key

/.quarto/
**/*.quarto_ipynb

# ---- LaTeX build artifacts (from quarto pdf renders) ------------------------
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz

# Voice clone sample — sensitive; keep local, not in VCS
assets/voice/*.m4a
assets/voice/*.wav
assets/voice/*.mp3
/_site/
/_freeze/

# rendered videos (large; on Hopper + YouTube)
videos/clips/
videos/*.mp4
!videos/upload_manifest.csv
